{
    "name": "cleanstream-api",
    "version": "1.0.0",
    "description": "Data Ingestion & Normalization API",
    "main": "src/index.ts",
    "scripts": {
        "dev": "bun run --watch src/index.ts",
        "start": "NODE_ENV=production bun run src/index.ts",
        "test": "bun test tests/*.test.ts --exclude tests/e2e.test.ts",
        "test:e2e": "bun test tests/e2e.test.ts",
        "test:all": "bun test",
        "typecheck": "bun x tsc --noEmit",
        "format": "bun x prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
        "format:check": "bun x prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
        "lint": "bun run format:check && bun run typecheck",
        "ci": "bun run lint && bun run test",
        "docker:build": "docker build -t cleanstream-api .",
        "docker:run": "docker run -p 3000:3000 -e API_KEY=test-api-key cleanstream-api"
    },
    "keywords": [
        "api",
        "data",
        "ingestion",
        "normalization"
    ],
    "license": "MIT",
    "dependencies": {
        "csv-parse": "^5.5.3",
        "dayjs": "^1.11.10",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "fast-xml-parser": "^4.3.2",
        "multer": "^1.4.5-lts.1",
        "uuid": "^9.0.1",
        "xlsx": "^0.18.5",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.10.6",
        "@types/uuid": "^9.0.7",
        "bun-types": "^1.0.0",
        "prettier": "^3.2.4",
        "typescript": "^5.3.3"
    }
}